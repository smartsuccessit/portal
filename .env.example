# Smart Success Portal — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000

# MySQL Database (Hostinger credentials)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# JWT Secret — change this to a long random string
JWT_SECRET=change-this-to-a-long-random-secret-string-in-production
